# ── Server Environment Variables ──────────────────────────────
# Copy this file to .env and fill in the values

# Port for the Express server
PORT=5000

# MongoDB connection string
# Replace <username>, <password>, <cluster> with your MongoDB Atlas credentials
# Or use mongodb://localhost:27017/kaammitra for a local MongoDB instance
MONGO_URI=mongodb://localhost:27017/kaammitra

# JWT secret for authentication (generate a random string)
JWT_SECRET=your_jwt_secret_here

# Google Gemini API Key (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
